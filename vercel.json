{
  "rewrites": [
    {
      "source": "/api/clanker/:path*",
      "destination": "https://www.clanker.world/api/:path*"
    },
    {
      "source": "/api/dexscreener/:path*",
      "destination": "https://api.dexscreener.com/:path*"
    },
    {
      "source": "/api/basescan/:path*",
      "destination": "https://api.basescan.org/:path*"
    }
  ]
}
